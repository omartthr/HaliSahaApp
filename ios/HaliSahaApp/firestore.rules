rules_version = '2';

// HaliSahaApp - Firestore Security Rules
//
// Bu kuralları Firebase Console > Firestore > Rules sekmesine yapıştırarak
// veya Firebase CLI ile (firebase deploy --only firestore:rules) yayına alabilirsin.
//
// Roller:
//  - player      : müşteri (varsayılan)
//  - admin       : saha sahibi (admins/{uid} kaydı olur; approvalStatus alanı)
//  - superAdmin  : platform yöneticisi (sadece Console'dan manuel atanır)
//
// Genel yaklaşım: minimum yetki — her rol sadece kendi sorumluluğundaki
// dokümanları/alanları yazabilir. Çapraz koleksiyon yazımları (örn. yorum
// yazınca tesisin ortalamasının güncellenmesi) için sıkı alan kısıtlaması
// kullanılır (onlyChanged + sayısal alan kontrolü).

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userTypeOf(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.userType;
    }

    function isSuperAdmin() {
      return isSignedIn() && userTypeOf(request.auth.uid) == 'superAdmin';
    }

    function isAdminUser() {
      return isSignedIn() && userTypeOf(request.auth.uid) == 'admin';
    }

    function isApprovedAdmin() {
      return isAdminUser()
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.approvalStatus == 'approved';
    }

    // Update sırasında değişen alanların verilen listede olmasını şart koşar.
    function onlyChanged(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Bir tesisin sahibi miyim?
    function isFacilityOwner(facilityId) {
      return isApprovedAdmin()
          && exists(/databases/$(database)/documents/facilities/$(facilityId))
          && get(/databases/$(database)/documents/facilities/$(facilityId)).data.ownerId == request.auth.uid;
    }

    // ---------- users/{userId} ----------
    match /users/{userId} {
      // Profilleri (giriş yapmış) herkes okuyabilir — keşif/oyuncu listesi için
      allow read: if isSignedIn();

      // Sadece kullanıcı kendi profilini oluşturabilir. superAdmin client'tan
      // oluşturulamaz; sadece Console'dan elle atanır.
      allow create: if isOwner(userId)
                    && request.resource.data.userType in ['player', 'admin'];

      // Kullanıcı kendi profilini güncelleyebilir AMA userType değiştiremez
      allow update: if isOwner(userId)
                    && request.resource.data.userType == resource.data.userType;

      // SuperAdmin başka kullanıcının (userType dahil) profilini güncelleyebilir
      allow update: if isSuperAdmin();

      // Hesap silme: kullanıcı kendi hesabını silebilir (AuthService.deleteAccount).
      // SuperAdmin de moderasyon amacıyla silebilir.
      allow delete: if isOwner(userId) || isSuperAdmin();
    }

    // ---------- admins/{adminId} ----------
    match /admins/{adminId} {
      // Tekil okuma: admin kendi profilini, superAdmin tüm profilleri okuyabilir
      allow get: if isOwner(adminId) || isSuperAdmin();
      // Listeleme: yalnız superAdmin (onay paneli için)
      allow list: if isSuperAdmin();

      // Kayıt akışında AdminProfile oluşturulur (registerAsAdmin)
      allow create: if isOwner(adminId)
                    && request.resource.data.approvalStatus == 'pending';

      // Saha sahibi sadece kendi belge & tercih alanlarını güncelleyebilir.
      // approvalStatus / reviewedBy / approvedAt gibi yetkili alanlara dokunamaz.
      allow update: if isOwner(adminId)
                    && onlyChanged([
                         'documents',
                         'documentsSubmittedAt',
                         'businessName',
                         'taxNumber',
                         'pushNotificationsEnabled',
                         'emailNotificationsEnabled',
                         'autoConfirmBookings',
                         'rejectionReason',
                         'updatedAt'
                       ]);

      // SuperAdmin tüm alanları güncelleyebilir (onay/red/askıya alma)
      allow update: if isSuperAdmin();

      // Silme yok (audit için tutulur)
      allow delete: if isSuperAdmin();
    }

    // ---------- facilities/{facilityId} ----------
    match /facilities/{facilityId} {
      // Tesisleri herkes (anonim dahil) okuyabilir — listeleme/keşif için
      allow read: if true;

      // Onaylı admin kendi adına tesis oluşturabilir
      allow create: if isApprovedAdmin()
                    && request.resource.data.ownerId == request.auth.uid;

      // 1) Tesis sahibi her alanı güncelleyebilir
      allow update: if isApprovedAdmin()
                    && resource.data.ownerId == request.auth.uid;

      // 2) SuperAdmin her alanı güncelleyebilir
      allow update: if isSuperAdmin();

      // 3) Giriş yapmış herhangi bir kullanıcı, SADECE yorum aggregasyonu
      //    alanlarını güncelleyebilir (ReviewService.updateFacilityRating).
      //    Bu kural, müşterinin yorum bıraktığında tesis ortalamasının
      //    transaction içinde güncellenebilmesi için zorunludur.
      allow update: if isSignedIn()
                    && onlyChanged(['averageRating', 'totalReviews', 'updatedAt'])
                    && request.resource.data.averageRating is number
                    && request.resource.data.averageRating >= 0
                    && request.resource.data.averageRating <= 5
                    && request.resource.data.totalReviews is int
                    && request.resource.data.totalReviews >= 0;

      // Silme: sahip veya superAdmin
      allow delete: if (isApprovedAdmin() && resource.data.ownerId == request.auth.uid)
                    || isSuperAdmin();

      // Pitches alt-koleksiyonu
      match /pitches/{pitchId} {
        allow read: if true;
        allow write: if (isApprovedAdmin()
                         && get(/databases/$(database)/documents/facilities/$(facilityId)).data.ownerId == request.auth.uid)
                      || isSuperAdmin();
      }
    }

    // ---------- bookings/{bookingId} ----------
    // NOT: Firestore'da `allow read` hem `get` (tek dokuman) hem de
    // `list` (sorgu) için çalışır. Sorgu sırasında kural her dokuman için
    // ayrı evaluate edilir; resource.data.* gibi koşullar sorgunun
    // tamamen reddine sebep olur. Bu yüzden get/list ayrılmış.
    match /bookings/{bookingId} {
      // Tek dokuman okuma: sıkı per-document kontrol.
      allow get: if isSignedIn() && (
                   resource.data.userId == request.auth.uid
                   || isSuperAdmin()
                   || (isApprovedAdmin()
                       && exists(/databases/$(database)/documents/facilities/$(resource.data.facilityId))
                       && get(/databases/$(database)/documents/facilities/$(resource.data.facilityId)).data.ownerId == request.auth.uid)
                 );

      // Sorgu: signed-in kullanıcılar listeleyebilir. Hem müşteri (kendi
      // rezervasyonları) hem admin (tesis rezervasyonları) hem superAdmin
      // farklı `where` koşullarıyla sorgu çekiyor — bu yüzden gevşek tutuldu.
      // Üretim sertleştirmesi: per-user subcollection'a taşıma.
      allow list: if isSignedIn();

      // Oyuncu rezervasyon oluşturabilir (kendi adına).
      // Yeni rezervasyonun ödeme durumu mutlaka `pending` olmalı —
      // ödemenin "yapılmış" şeklinde işaretlenmesi sadece iyzicoCallback
      // Cloud Function'ı tarafından (admin SDK ile) yapılabilir.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.paymentStatus == 'pending';

      // Güncelleme yetkisi: kendi rezervasyonu, tesis sahibi veya superAdmin.
      // Ek olarak, client yalnızca aşağıdaki alanları değiştirebilir.
      // `paymentStatus`, `qrCode`, `ticketNumber`, fiyat ve kimlik alanları
      // sadece server-side (iyzicoCallback / refundDeposit) tarafından
      // güncellenebilir. SuperAdmin için bu kısıt yok (manuel müdahale).
      allow update: if isSignedIn() && (
                       isSuperAdmin()
                       || (
                         (resource.data.userId == request.auth.uid
                          || (isApprovedAdmin()
                              && exists(/databases/$(database)/documents/facilities/$(resource.data.facilityId))
                              && get(/databases/$(database)/documents/facilities/$(resource.data.facilityId)).data.ownerId == request.auth.uid))
                         && onlyChanged([
                              'status',
                              'cancellationReason',
                              'cancelledAt',
                              'updatedAt',
                              'groupId'
                            ])
                       )
                     );

      // Silme: superAdmin (audit için müşteri/admin silemez)
      allow delete: if isSuperAdmin();
    }

    // ---------- payments/{paymentId} ----------
    // iyzico ödeme akışında server-side fonksiyonların yazdığı kayıtlar.
    // iOS uygulaması `IyzicoPaymentView` içinde kendi ödemesinin sonucunu
    // izlemek için listener kurar — bu yüzden okuma sahibine açıktır.
    // Yazma her zaman reddedilir; sadece Admin SDK (Cloud Functions)
    // güvenlik kurallarını bypass ederek yazabilir.
    match /payments/{paymentId} {
      allow get: if isSignedIn()
                 && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow write: if false;
    }

    // ---------- notifications/{notificationId} ----------
    // Her bildirim bir hedef userId taşır. Sahibi okuyup işaretleyebilir,
    // silebilir. Yazma: signed-in herkes (admin müşteriye, müşteri admine
    // bildirim yazıyor); spam riskini server-side Cloud Functions ile
    // kısıtlamak ileride mümkün.
    match /notifications/{notificationId} {
      allow get: if isSignedIn()
                 && (resource.data.userId == request.auth.uid || isSuperAdmin());

      // list: client kendi userId'sini filtreliyor; per-doc resource kontrolü
      // sorguyu reddeder, bu yüzden signed-in yetiyor.
      allow list: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['userId', 'title', 'body', 'type'])
                    && request.resource.data.userId is string;

      // Sadece bildirimin sahibi (okundu işareti ve davet durumu) veya superAdmin güncelleyebilir.
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && onlyChanged(['isRead', 'status', 'updatedAt']);
      allow update: if isSuperAdmin();

      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // ---------- reviews/{reviewId} ----------
    // Saha değerlendirmeleri. Okuma herkese açık (login olmayan da görsün).
    match /reviews/{reviewId} {
      allow read: if true;

      // Sadece kendi adıyla, gerçek rezervasyonu olan kullanıcı yorum bırakabilir.
      // bookingId / userId tutarlılığını client tarafı sağlar; rules tarafında
      // userId'nin auth.uid'e eşitliği zorunlu.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.overallRating is number
                    && request.resource.data.overallRating >= 0
                    && request.resource.data.overallRating <= 5;

      // Güncelleme: yorum sahibi düzenleyebilir; superAdmin moderasyon yapabilir;
      // tesis sahibi sadece admin yanıtı / gizleme alanlarına dokunabilir.
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
      allow update: if isSuperAdmin();
      allow update: if isFacilityOwner(resource.data.facilityId)
                    && onlyChanged(['adminReply', 'adminReplyDate', 'isHidden', 'updatedAt']);

      // Silme: yorum sahibi veya superAdmin
      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // ---------- user_reliability_reviews/{reviewId} ----------
    // Saha sahibinin kullanıcı hakkında verdiği güvenilirlik puanı.
    match /user_reliability_reviews/{reviewId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.reviewerId == request.auth.uid;

      allow update, delete: if isSignedIn()
                            && (resource.data.reviewerId == request.auth.uid || isSuperAdmin());
    }

    // ---------- playerRatings/{ratingId} ----------
    // Oyuncuların birbirlerini değerlendirdiği puanlar.
    match /playerRatings/{ratingId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn()
                    && request.resource.data.raterId == request.auth.uid
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;

      allow update, delete: if isSignedIn()
                            && (resource.data.raterId == request.auth.uid || isSuperAdmin());
    }

    // ---------- match_posts/{postId} ----------
    // Oyuncuların açtığı maç ilanları. Listeleme herkese açık (signed-in).
    match /match_posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.creatorId == request.auth.uid;

      // (a) Sahibi her alanı güncelleyebilir (accept/reject, currentPlayers vb.).
      // creatorId immutable.
      allow update: if isSignedIn()
                    && resource.data.creatorId == request.auth.uid
                    && request.resource.data.creatorId == resource.data.creatorId;

      // (b) SuperAdmin moderasyon yapabilir.
      allow update: if isSuperAdmin();

      // (c) Üçüncü kişi: ilana SADECE kendisini başvuran olarak ekleyebilir
      //     veya başvurusunu geri çekebilir. `acceptedIds`/`rejectedIds`/
      //     `currentPlayers` gibi alanlara ASLA dokunamaz.
      allow update: if isSignedIn()
                    && onlyChanged(['applicantIds', 'updatedAt'])
                    && request.resource.data.applicantIds is list
                    && (
                         // self-apply: yeni listede ben varım, eskide yoktum, başka kimse eklenmedi/çıkmadı
                         (
                           request.auth.uid in request.resource.data.applicantIds
                           && !(request.auth.uid in resource.data.applicantIds)
                           && request.resource.data.applicantIds.size() == resource.data.applicantIds.size() + 1
                           && request.resource.data.applicantIds.hasAll(resource.data.applicantIds)
                         )
                         ||
                         // self-withdraw: eskide vardım, yenide yokum, başka kimse değişmedi
                         (
                           !(request.auth.uid in request.resource.data.applicantIds)
                           && request.auth.uid in resource.data.applicantIds
                           && request.resource.data.applicantIds.size() == resource.data.applicantIds.size() - 1
                           && resource.data.applicantIds.hasAll(request.resource.data.applicantIds)
                         )
                       );

      allow delete: if isSignedIn()
                    && (resource.data.creatorId == request.auth.uid || isSuperAdmin());
    }

    // ---------- groups/{groupId} ----------
    // Sohbet grupları: yalnız `memberIds` içindeki kullanıcılar okuyup yazabilir.
    // Yol 1 (ilan kabul) akışında host (creator) `memberIds`'i günceller.
    // Yol 2 (manuel davet) akışı Aşama 4'te `pendingInviteIds` alanıyla eklenecek.
    match /groups/{groupId} {

      // Üye mi?
      // NOT: `is list` kontrolü yok — `arrayContains` query filtresi zaten alanın
      // array olduğunu zorunlu kılar; ek kontrol Firestore'un statik analizini
      // yanıltıp liste sorgularını yanlışlıkla reddetmesine sebep olabiliyor.
      function isGroupMember() {
        return isSignedIn()
            && request.auth.uid in resource.data.memberIds;
      }

      // Kurucu veya admin mi?
      function isGroupCreatorOrAdmin() {
        return isSignedIn()
            && (resource.data.creatorId == request.auth.uid
                || (resource.data.adminIds is list
                    && request.auth.uid in resource.data.adminIds));
      }

      // Okuma: yalnız üyeler. (Client `memberIds arrayContains` filtresiyle sorgular.)
      // ÖNEMLİ: SuperAdmin durumunu ayrı `allow read`'a aldık. Tek `if A || B`
      // şeklinde yazıldığında Firestore statik analizi `isSuperAdmin()`'i
      // ispatlayamadığı için tüm sorguyu reddedebiliyor. İki ayrı satır halinde
      // her biri bağımsız ispatlanır; birinin geçmesi yeterli.
      allow read: if isGroupMember();
      allow read: if isSuperAdmin();

      // Oluşturma: signed-in, creatorId == auth.uid, ve kurucu memberIds içinde.
      // matchGroup ise `linkedBookingId` zorunlu (otomatik üretim akışı).
      allow create: if isSignedIn()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.memberIds is list
                    && request.auth.uid in request.resource.data.memberIds
                    && request.resource.data.memberIds.size() <= request.resource.data.maxMembers;

      // (a) Kurucu/admin: her alanı güncelleyebilir (üye ekleme/çıkarma dahil).
      allow update: if isGroupCreatorOrAdmin();

      // (b) Üye: yalnız son mesaj önizlemesini güncelleyebilir (mesaj atınca).
      allow update: if isGroupMember()
                    && onlyChanged(['lastMessage', 'updatedAt']);

      // (c) Üye: gruptan KENDİSİNİ çıkarabilir (başkasını çıkaramaz).
      allow update: if isGroupMember()
                    && onlyChanged(['memberIds', 'updatedAt'])
                    && !(request.auth.uid in request.resource.data.memberIds)
                    && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;

      // Silme: yalnız kurucu veya superAdmin.
      allow delete: if isSignedIn()
                    && (resource.data.creatorId == request.auth.uid || isSuperAdmin());

      // ---------- Mesajlar (subcollection) ----------
      match /messages/{messageId} {

        // Parent grubun üyesi mi? (get ile tek seferlik kontrol)
        function isParentGroupMember() {
          return isSignedIn()
              && exists(/databases/$(database)/documents/groups/$(groupId))
              && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
        }

        // Okuma: yalnız grup üyeleri. (OR yerine ayrı satırlar — statik analiz için.)
        allow read: if isParentGroupMember();
        allow read: if isSuperAdmin();

        // Oluşturma: grup üyesi olmalı, kendi adına yazmalı, içerik <= 2000 karakter.
        // Sistem mesajları client tarafından yazılmaz; service layer addMember/leaveMember
        // sırasında host'un yetkisiyle yazılır (host zaten üye).
        allow create: if isParentGroupMember()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.groupId == groupId
                      && request.resource.data.content is string
                      && request.resource.data.content.size() <= 2000;

        // Düzenleme: yalnız kendi mesajını, 15 dakika içinde, sadece içerik/edit/silme alanları.
        allow update: if isSignedIn()
                      && resource.data.senderId == request.auth.uid
                      && onlyChanged(['content', 'isEdited', 'isDeleted', 'updatedAt'])
                      && (request.time.toMillis() - resource.data.createdAt.toMillis()) < 15 * 60 * 1000;

        // Okundu işareti: herhangi bir üye sadece KENDİSİNİ readBy'a ekleyebilir,
        // mevcut işaretleri silemez.
        allow update: if isParentGroupMember()
                      && onlyChanged(['readBy', 'updatedAt'])
                      && request.resource.data.readBy.hasAll(resource.data.readBy)
                      && request.auth.uid in request.resource.data.readBy;

        // Silme: yalnız mesaj sahibi veya superAdmin (soft-delete tercih edilmeli).
        allow delete: if isSignedIn()
                      && (resource.data.senderId == request.auth.uid || isSuperAdmin());
      }
    }

    // ---------- supportTickets/{ticketId} ----------
    // Destek talepleri: Sadece giriş yapmış kullanıcılar oluşturabilir.
    // Okuma/Düzenleme/Silme sadece superAdmin tarafından yapılabilir.
    match /supportTickets/{ticketId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSuperAdmin();
    }

    // ---------- SuperAdmin catch-all ----------
    // Bilinmeyen koleksiyonlar için yalnız superAdmin erişimi.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
